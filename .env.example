# HubSpot Private App token
# Create one at: Settings → Integrations → Private Apps
HUBSPOT_TOKEN=your_private_app_token_here

# HubSpot pipeline config
# Find these at: Settings → Objects → Tickets → Pipelines
HUBSPOT_PIPELINE_ID=your_pipeline_id_here
HUBSPOT_PIPELINE_STAGE_ID=your_pipeline_stage_id_here

# Server port (Replit sets this automatically)
PORT=3000
